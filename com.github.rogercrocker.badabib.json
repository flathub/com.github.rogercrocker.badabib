{
    "app-id" : "com.github.rogercrocker.badabib",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "command" : "badabib",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--filesystem=home",
        "--device=dri"
    ],
    "cleanup-commands": [
        "python3 -m compileall --invalidation-mode=unchecked-hash /app"
    ],
    "modules" : [
        "bibtexparser.json",
        {
            "name" : "badabib",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/RogerCrocker/BadaBib.git",
                    "tag": "v0.8.1",
                    "commit": "88a2db263b090975276d53a25fce696cccaf1304"
                },
                {
                    "type" : "patch",
                    "path": "fix_appdata.patch"
                }
            ]
        }
    ]
}
